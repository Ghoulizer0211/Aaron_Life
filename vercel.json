{
  "functions": {
    "api/teller.js": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/api/teller/:path*",    "destination": "/api/teller" },
    { "source": "/api/finance/:path*",   "destination": "/api/finance" },
    { "source": "/api/snaptrade/:path*", "destination": "/api/snaptrade" },
    { "source": "/api/oura/:path*",      "destination": "/api/oura" },
    { "source": "/api/gym/:path*",       "destination": "/api/gym" },
    { "source": "/((?!api).*)",          "destination": "/" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",           "value": "DENY" },
        { "key": "X-Content-Type-Options",     "value": "nosniff" },
        { "key": "Referrer-Policy",            "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",         "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security",  "value": "max-age=63072000; includeSubDomains; preload" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://*.teller.io https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com https://*.teller.io; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://*.supabase.co https://*.teller.io; img-src 'self' data: https:; frame-src https://teller.io https://*.teller.io; frame-ancestors 'none'"
        }
      ]
    }
  ]
}
